# 请将此文件重命名为 .env.local 并填入你的 API Key

# 1. 你的 API Key（必填）
OPENAI_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxx"

# 2. 如果你使用第三方代理或者其他兼容 OpenAI 接口的模型，请修改 Base URL
# 例如 豆包 (火山引擎): https://ark.cn-beijing.volces.com/api/v3
# 例如 DeepSeek: https://api.deepseek.com/v1
# 例如 硅基流动: https://api.siliconflow.cn/v1
OPENAI_BASE_URL="https://api.openai.com/v1"

# 3. 使用的模型名称（可选，根据服务商填写对应的模型）
# 例如 豆包 (火山引擎): ep-xxxxxxxx-xxxx (需要去控制台获取接入点ID)
# 例如 DeepSeek: deepseek-chat
# 例如 硅基流动: deepseek-ai/DeepSeek-V3
OPENAI_MODEL="gpt-3.5-turbo"

# ==========================================
# 📷 真实高清商业图库 API 配置 (彻底解决防盗链和文不对题)
# ==========================================

# 4. Pexels API Key（选填）
# 如果你配置了这个 Key，AI 排版公众号文章时将去 Pexels 抓取真实的高清商业摄影图，并生成静态防盗链链接。
# 申请地址: https://www.pexels.com/api/
PEXELS_API_KEY=""

# 5. SiliconFlow 硅基流动 API Key（选填）
# 如果你配置了这个 Key，右侧侧边栏的“✨ AI 生图”按钮将调用地表最强的开源模型 FLUX.1-dev 为你生成极高画质的配图。
# 申请地址: https://cloud.siliconflow.cn/ (注册即送 14 元免费额度，能画上百张图)
SILICONFLOW_API_KEY=""
